{
	"schemaVersion": "0.1.0",
	"name": "Ikea",
	"behavior": "create",
	"noteContentFormat": "# {{title}}\n\n{{schema:@Product:image|template:\"${contentUrl}\"|split:\\n\\n|image|list}}\n\n## Oversikt\n\n{{selectorHtml:.pipf-overview-summary__description|markdown}}\n\n## Produktdetaljer\n\n{{selectorHtml:.pipf-product-details-tab .pipf-product-details-modal__container|first|markdown}}\n\n## Dokumenter\n\n{{selector:a.pipf-product-details-modal__document-link?href|unique|image|list}}",
	"properties": [
		{
			"name": "url",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "title",
			"value": "{{title}}",
			"type": "text"
		},
		{
			"name": "productID",
			"value": "{{schema:@Product:mpn}}",
			"type": "text"
		},
		{
			"name": "price",
			"value": "{{schema:@Product:offers.price}} {{schema:@Product:offers.priceCurrency}}",
			"type": "text"
		},
		{
			"name": "tags",
			"value": "product",
			"type": "multitext"
		},
		{
			"name": "brand",
			"value": "{{schema:@Product:brand.name}}",
			"type": "text"
		},
		{
			"name": "color",
			"value": "{{schema:@Product:color}}",
			"type": "text"
		},
		{
			"name": "width",
			"value": "{{schema:@Product:width}}",
			"type": "text"
		},
		{
			"name": "height",
			"value": "{{schema:@Product:height}}",
			"type": "text"
		},
		{
			"name": "depth",
			"value": "{{schema:@Product:depth}}",
			"type": "text"
		}
	],
	"triggers": [
		"https://www.ikea.com/"
	],
	"noteNameFormat": "{{title|safe_name}}",
	"path": "3 Ressurser/Ønskeliste/{{domain}}"
}