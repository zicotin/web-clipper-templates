{
	"schemaVersion": "0.1.0",
	"name": "Goodreads",
	"behavior": "create",
	"noteContentFormat": "{{selectorHtml:h1.Text__title1|markdown}}\n\n{{selectorHtml:.BookPageMetadataSection__description|markdown}}",
	"properties": [
		{
			"name": "title",
			"value": "{{selector:h1.Text__title1}}",
			"type": "text"
		},
		{
			"name": "authors",
			"value": "{{schema:author[*].name|join}}",
			"type": "multitext"
		},
		{
			"name": "genre",
			"value": "{{selector:.BookPageMetadataSection__genres .BookPageMetadataSection__genreButton|lower}}",
			"type": "multitext"
		},
		{
			"name": "numberOfPages",
			"value": "{{schema:numberOfPages}}",
			"type": "text"
		},
		{
			"name": "year",
			"value": "{{selector:p[data-testid='publicationInfo']|split:\\\"First published \\\"|slice:1|date:\\\"YYYY\\\"}}",
			"type": "number"
		},
		{
			"name": "image",
			"value": "{{schema:image}}",
			"type": "text"
		},
		{
			"name": "isbn",
			"value": "{{schema:isbn}}",
			"type": "text"
		},
		{
			"name": "language",
			"value": "{{schema:inLanguage}}",
			"type": "text"
		},
		{
			"name": "dateCreated",
			"value": "{{date}}",
			"type": "datetime"
		},
		{
			"name": "tags",
			"value": "clippings, books",
			"type": "multitext"
		},
		{
			"name": "url",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "isPartOf",
			"value": "{{selector:.BookPageTitleSection__title h3.Text__title3|split:\\\" #\\\"|first}}",
			"type": "text"
		},
		{
			"name": "position",
			"value": "{{selector:.BookPageTitleSection__title h3.Text__title3|split:\\\" #\\\"|last}}",
			"type": "text"
		}
	],
	"triggers": [
		"https://www.goodreads.com/book/"
	],
	"noteNameFormat": "{{selector:h1.Text__title1|safe_name}} by {{schema:author[*].name|join|safe_name}}",
	"path": "0 Innboks/{{domain}}"
}