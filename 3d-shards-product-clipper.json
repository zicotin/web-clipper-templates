{
	"schemaVersion": "0.1.0",
	"name": "3D Shards product",
	"behavior": "create",
	"noteContentFormat": "{{selectorHtml:#tab-description|markdown}}",
	"properties": [
		{
			"name": "aliases",
			"value": "{{selector:h1.product_title}}",
			"type": "multitext"
		},
		{
			"name": "url",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "productID",
			"value": "{{selector:.product-sku strong|first}}",
			"type": "text"
		},
		{
			"name": "artists",
			"value": "{{selector:.wcfmmp_sold_by_store a}}",
			"type": "multitext"
		},
		{
			"name": "dateCreated",
			"value": "{{time|date:\\\"YYYY-MM-DDTHH:mm:ssZ\\\"}}",
			"type": "datetime"
		},
		{
			"name": "originalPrice",
			"value": "{{meta:property:og:price:standard_amount}} {{meta:property:product:price:currency}}",
			"type": "text"
		},
		{
			"name": "purchasePrice",
			"value": "{{meta:property:product:price:amount}} {{meta:property:product:price:currency}}",
			"type": "text"
		},
		{
			"name": "releaseDate",
			"value": "{{meta:property:article:published_time}}",
			"type": "date"
		},
		{
			"name": "orderID",
			"value": "",
			"type": "text"
		},
		{
			"name": "orderDate",
			"value": "{{time|date:\\\"YYYY-MM-DD\\\"}}",
			"type": "date"
		},
		{
			"name": "tags",
			"value": "ds-asset",
			"type": "multitext"
		},
		{
			"name": "image",
			"value": "{{image}}",
			"type": "text"
		}
	],
	"triggers": [
		"https://3dshards.com/product/"
	],
	"noteNameFormat": "{{selector:h1.product_title|safe_name}}",
	"path": "4 Ressurser/Daz Studio Assets/3D Shards/3d shards products"
}